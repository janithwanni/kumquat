library(randomForest)
library(tidyverse)
library(bundle)
library(glmnet)
set.seed(345)
train_data <- readr::read_csv(here::here("inst/train_data.csv"))
rfmodel <- randomForest(
class ~ x + y,
data = train_data |> mutate(class = factor(class))
)
rfmodel_bundled <- bundle(rfmodel)
pred_fn <- function(model, data) {
library(randomForest)
predict(rfmodel, data)
}
# Select a point of interest
poi <- 2554
ggplot(train_data, aes(x = x, y = y, color = class)) +
geom_point() +
geom_label(
data = train_data |> mutate(id = row_number()),
aes(label = id),
size = 5
)
library(kumquat)
library(randomForest)
library(tidyverse)
library(bundle)
library(glmnet)
set.seed(345)
theme_set(theme_minimal())
train_data <- readr::read_csv(here::here("inst/train_data.csv"))
rfmodel <- randomForest(
class ~ x + y,
data = train_data |> mutate(class = factor(class))
)
rfmodel_bundled <- bundle(rfmodel)
sfun <- function(k) {
return(glue::glue(
"x = {k$local_model$importances[1] |> round(2)}, y = {k$local_model$importances[2] |> round(2)}"
))
}
pfun <- function(k) {
ggplot(
data = k$perturbations |> mutate(pred = k$local_model$glm_predictions),
aes(x = x, y = y, color = pred)
) +
geom_point(alpha = 0.5, shape = 17) +
geom_point(data = train_data, aes(color = class), alpha = 0.1) +
# lims(x = c(-0.4, 0.4), y = c(-0.5, 0)) +
labs(subtitle = sfun(k)) +
theme_minimal()
}
poi <- 2554
k <- kumquat(rfmodel_bundled, train_data, poi)
names(k)
k$local_model |> names()
k$local_model$importances
pfun()
pfun(k)
poi <- 2487
k <- kumquat(rfmodel_bundled, train_data, poi)
k$local_model$importances
pfun(k)
poi <- 2554
k <- kumquat(rfmodel_bundled, train_data, poi)
k$local_model$importances
pfun(k)
poi <- 2530
k <- kumquat(rfmodel_bundled, train_data, poi)
k$local_model$importances
pfun(k)
poi <- 2195
k <- kumquat(rfmodel_bundled, train_data, poi)
k$local_model$importances
pfun(k)
